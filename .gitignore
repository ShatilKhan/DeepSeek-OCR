.env
.env.local
.env.*.local

# Local config / caches
.claude/
.gradio/
.playwright-mcp/

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
*.egg-info/

# Legacy upstream default output path
your/

# Validation datasets — allow-list pattern: block all downloaded data,
# only commit our own metadata files (provenance + manifests we generate).
# The download scripts in scripts/ can always rehydrate the data.
validation_set/**/*
!validation_set/**/
!validation_set/README.md
!validation_set/**/README.md
!validation_set/**/source.txt
!validation_set/**/manifest.csv

# Evaluation outputs
eval/results/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
