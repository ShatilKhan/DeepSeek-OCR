# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# Roboflow API — for dataset downloads ONLY (use PUBLISHABLE/public key, NOT private)
# Get from: https://app.roboflow.com/settings/api
ROBOFLOW_API_KEY=

# Kaggle API credentials — for dataset downloads
# Get from: https://www.kaggle.com/settings (API section → Create New Token → download kaggle.json)
KAGGLE_USERNAME=
KAGGLE_KEY=
